generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admins {
  id             String           @id
  username       String           @unique
  password       String
  name           String?
  role           Role             @default(ADMIN)
  pin            String?
  created_at     DateTime         @default(now())
  updated_at     DateTime
  sku_stock_logs sku_stock_logs[]
  stock_logs     stock_logs[]
  transactions   transactions[]
}

model banners {
  id         String   @id
  title      String?
  image_url  String
  image_key  String
  link_url   String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

model categories {
  id                 String               @id
  name               String
  short_description  String?
  image_url          String
  image_key          String?
  is_active          Boolean              @default(true)
  order              Int                  @default(0)
  product_categories product_categories[]
}

model product_categories {
  product_id  String
  category_id String
  assigned_at DateTime   @default(now())
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade)
  products    products   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([product_id, category_id])
}

model product_details {
  id               String          @id
  product_id       String          @unique
  description      String
  notes            String?
  closure_type     String?
  origin           String?
  size_template_id String?
  material         String?
  outsole          String?
  products         products        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  size_templates   size_templates? @relation(fields: [size_template_id], references: [id])
}

model product_images {
  id         String   @id
  url        String
  image_key  String
  product_id String
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model product_skus {
  id                  String                @id
  size                String
  stock               Int                   @default(0)
  price_override      Decimal?              @db.Decimal(12, 2)
  is_active           Boolean               @default(true)
  variant_id          String
  created_at          DateTime              @default(now())
  updated_at          DateTime
  product_variants    product_variants      @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  sku_sales_summaries sku_sales_summaries[]
  sku_stock_logs      sku_stock_logs[]
  transaction_items   transaction_items[]

  @@unique([variant_id, size])
}

model product_variant_images {
  id               String           @id
  url              String
  image_key        String
  variant_id       String
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade)
}

model product_variants {
  id                     String                   @id
  variant_code           String                   @unique
  color                  String
  base_price             Decimal                  @db.Decimal(12, 2)
  discount_percent       Float?
  is_active              Boolean                  @default(true)
  product_id             String
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  comparison_price       Decimal?                 @db.Decimal(12, 2)
  product_skus           product_skus[]
  product_variant_images product_variant_images[]
  products               products                 @relation(fields: [product_id], references: [id], onDelete: Cascade)
  transaction_items      transaction_items[]
}

model products {
  id                  String                @id
  product_code        String                @unique
  name                String
  short_description   String
  price               Decimal?              @db.Decimal(12, 2)
  stock               Int                   @default(0)
  product_type        String
  gender              String                @default("Unisex")
  is_popular          Boolean               @default(false)
  is_bestseller       Boolean               @default(false)
  is_new              Boolean               @default(true)
  is_active           Boolean               @default(true)
  avg_rating          Float                 @default(0)
  total_reviews       Int                   @default(0)
  created_at          DateTime              @default(now())
  updated_at          DateTime
  product_categories  product_categories[]
  product_details     product_details?
  product_images      product_images[]
  product_variants    product_variants[]
  sku_sales_summaries sku_sales_summaries[]
  stock_logs          stock_logs[]
  testimonials        testimonials[]
  transaction_items   transaction_items[]
}

model promos {
  id           String      @id
  name         String
  description  String?
  type         PromoType
  value        Decimal     @db.Decimal(12, 2)
  target_type  PromoTarget
  target_ids   String[]
  min_purchase Decimal     @default(0) @db.Decimal(12, 2)
  is_active    Boolean     @default(true)
  start_date   DateTime
  end_date     DateTime
  created_at   DateTime    @default(now())
  updated_at   DateTime
}

model size_templates {
  id              String            @id
  name            String
  type            String
  sizes           String[]
  created_at      DateTime          @default(now())
  updated_at      DateTime
  product_details product_details[]
}

model sku_sales_summaries {
  id            String        @id
  date          DateTime
  sku_id        String?
  product_id    String
  product_name  String
  product_code  String
  variant_color String        @default("-")
  sku_size      String        @default("-")
  total_qty     Int           @default(0)
  total_revenue Decimal       @default(0) @db.Decimal(12, 2)
  total_orders  Int           @default(0)
  created_at    DateTime      @default(now())
  updated_at    DateTime
  products      products      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_skus  product_skus? @relation(fields: [sku_id], references: [id])

  @@unique([date, product_id, variant_color, sku_size])
  @@index([date])
}

model sku_stock_logs {
  id            String       @id
  sku_id        String
  delta         Int
  current_stock Int
  size          String
  color         String
  type          String
  notes         String?
  operator_id   String?
  created_at    DateTime     @default(now())
  admins        admins?      @relation(fields: [operator_id], references: [id])
  product_skus  product_skus @relation(fields: [sku_id], references: [id])
}

model stock_logs {
  id            String   @id
  product_id    String
  delta         Int
  current_stock Int
  type          String
  notes         String?
  operator_id   String?
  created_at    DateTime @default(now())
  admins        admins?  @relation(fields: [operator_id], references: [id])
  products      products @relation(fields: [product_id], references: [id])
}

model testimonials {
  id            String   @id
  product_id    String
  customer_name String
  rating        Int      @default(5)
  content       String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  products      products @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model transaction_items {
  id                       String            @id
  quantity                 Int
  price_at_sale            Decimal           @db.Decimal(12, 2)
  product_name             String
  transaction_id           String
  product_id               String
  product_code             String?
  discount_amount          Decimal           @default(0) @db.Decimal(12, 2)
  sku_id                   String?
  sku_size                 String?
  variant_color            String?
  variant_id               String?
  comparison_price_at_sale Decimal?          @db.Decimal(12, 2)
  promo_name               String?
  products                 products          @relation(fields: [product_id], references: [id])
  product_skus             product_skus?     @relation(fields: [sku_id], references: [id])
  transactions             transactions      @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  product_variants         product_variants? @relation(fields: [variant_id], references: [id])
}

model transactions {
  id                String              @id
  invoice_no        String              @unique
  total_price       Decimal             @db.Decimal(12, 2)
  amount_paid       Decimal             @db.Decimal(12, 2)
  change            Decimal             @db.Decimal(12, 2)
  status            TransactionStatus   @default(PAID)
  notes             String?
  cancel_reason     String?
  kasir_id          String
  created_at        DateTime            @default(now())
  customer_name     String?
  customer_phone    String?
  transaction_items transaction_items[]
  admins            admins              @relation(fields: [kasir_id], references: [id])
}

enum PromoTarget {
  GLOBAL
  CATEGORY
  PRODUCT
  VARIANT
}

enum PromoType {
  PERCENTAGE
  NOMINAL
}

enum Role {
  ADMIN
  KASIR
}

enum TransactionStatus {
  PAID
  VOID
}


