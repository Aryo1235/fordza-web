generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String         @id @default(cuid())
  name             String
  shortDescription String         @map("short_description")
  description      String         @db.Text
  price            Decimal        @db.Decimal(12, 2)
  productType      String         @map("product_type") // shoes, apparel, accessories
  isPopular        Boolean        @default(false) @map("is_popular")
  isBestseller     Boolean        @default(false) @map("is_bestseller")
  isNew            Boolean        @default(true) @map("is_new")
  isActive         Boolean        @default(true) @map("is_active")
  images           ProductImage[]
  categories       Category[]     @relation("ProductToCategory")
  gender           String         @default("Unisex")
  testimonials     Testimonial[]
  sizeTemplateId   String?
  sizeTemplate     SizeTemplate?  @relation(fields: [sizeTemplateId], references: [id])
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  key       String // Menyimpan path file di Supabase (untuk hapus file)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Category {
  id               String    @id @default(cuid())
  name             String
  shortDescription String?   @map("short_description")
  imageUrl         String    @map("image_url")
  imageKey         String?   @map("image_key") // Tambahan: Key untuk hapus foto kategori
  isActive         Boolean   @default(true) @map("is_active")
  order            Int       @default(0)
  products         Product[] @relation("ProductToCategory")
}

model SizeTemplate {
  id        String    @id @default(cuid())
  name      String // Contoh: "Sepatu Dewasa EU"
  type      String // Contoh: "Shoes" atau "Apparel"
  sizes     String[] // Simpan array string: ["39", "40", "41"]
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName String
  rating       Int      @default(5)
  content      String   @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Banner {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String   @map("image_url")
  imageKey  String   @map("image_key") // Key untuk hapus foto banner
  linkUrl   String?  @map("link_url") // Redirect saat banner diklik
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
}
