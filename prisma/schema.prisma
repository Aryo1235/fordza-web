// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init




generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String         @id @default(cuid())
  name             String
  shortDescription String         @map("short_description")
  description      String         @db.Text
  price            Decimal        @db.Decimal(12, 2)
  productType      String         @map("product_type") // shoes, apparel, accessories
  isPopular        Boolean        @default(false) @map("is_popular")
  isBestseller     Boolean        @default(false) @map("is_bestseller")
  isNew            Boolean        @default(true) @map("is_new")
  isActive         Boolean        @default(true) @map("is_active")
  images           ProductImage[]
  categories       Category[]     @relation("ProductToCategory")
  testimonials     Testimonial[]
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  key       String  // Untuk Cloudflare R2 nantinya
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Category {
  id               String    @id @default(cuid())
  name             String
  shortDescription String?   @map("short_description")
  imageUrl         String    @map("image_url")
  isActive         Boolean   @default(true) @map("is_active")
  order            Int       @default(0)
  products         Product[] @relation("ProductToCategory")
}

model Testimonial {
  id           String   @id @default(cuid())
  customerName String   @map("customer_name")
  rating       Int      @default(5)
  content      String   @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
}
