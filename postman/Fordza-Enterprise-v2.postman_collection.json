  "item": [
    {
      "name": "01. Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 2xx\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]); });",
                  "pm.test(\"Response has traceId\", function () { ",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('traceId');",
                  "});",
                  "if(pm.response.code === 200) { pm.environment.set('access_token', pm.response.json().data.accessToken); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
