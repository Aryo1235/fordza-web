      "name": "99. Error Scenarios (Test)",
      "item": [
        {
          "name": "Test 404 (Not Found)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/products/invalid-id",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "products",
                "invalid-id"
              ]
            },
            "description": ""
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404\", function () { pm.response.to.have.status(404); });",
                  "pm.test(\"Has error message and traceId\", function () { ",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.false;",
                  "    pm.expect(jsonData).to.have.property('traceId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
